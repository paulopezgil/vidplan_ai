# ============================================
# LLM Provider Configuration
# For available providers and their required environment variables,
# refer to: https://ai.pydantic.dev/models/overview/
# ============================================

# OpenAI Configuration (default)
OPENAI_API_KEY=sk-your-api-key-here
AI_MODEL=openai:gpt-4o-mini

# For other providers (Anthropic, DeepSeek, Google, Mistral, Groq, Cohere, etc.):
# 1. Set AI_MODEL to the provider:model format (e.g., "anthropic:claude-3-5-sonnet")
# 2. Set the corresponding API key environment variable
# 3. See Pydantic AI documentation for exact variable names

# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=vidplan
EMBED_DIM=1536

# ============================================
# Frontend Configuration (optional)
# ============================================
API_URL=http://backend:8000
